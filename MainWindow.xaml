<Window x:Class="Spocky.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Spocky"
        Height="720"
        Width="1180"
        WindowStyle="None"
        ResizeMode="CanResize"
        AllowsTransparency="True"
        Background="Transparent"
        FontFamily="Oswald, Antonio, 'Segoe UI', 'Arial Narrow', Arial, sans-serif"
        Loaded="OnLoaded"
        MouseLeftButtonDown="HandleWindowDrag">
    <Window.Resources>
        <Style x:Key="LcarsNavButton" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource LcMutedOrange}" />
            <Setter Property="BorderBrush" Value="{StaticResource LcMutedOrange}" />
            <Setter Property="Foreground" Value="{StaticResource LcBackground}" />
            <Setter Property="FontSize" Value="22" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Height" Value="48" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="12">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="LcarsChipButton" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource LcMutedOrange}" />
            <Setter Property="BorderBrush" Value="{StaticResource LcMutedOrange}" />
            <Setter Property="Foreground" Value="{StaticResource LcBackground}" />
            <Setter Property="FontSize" Value="16" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Padding" Value="14,6" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="LcarsComboBox" TargetType="ComboBox">
            <Setter Property="Background" Value="{StaticResource LcViolet}" />
            <Setter Property="BorderBrush" Value="{StaticResource LcViolet}" />
            <Setter Property="Foreground" Value="{StaticResource LcBackground}" />
            <Setter Property="FontSize" Value="16" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Padding" Value="8,2" />
        </Style>
    </Window.Resources>
    <Border Background="{StaticResource LcBackground}" CornerRadius="18" Padding="0" BorderBrush="{StaticResource LcMutedOrange}" BorderThickness="2">
        <Grid Margin="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="260" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- LCARS Navigation Column -->
            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="120" />
                </Grid.RowDefinitions>

                <Canvas Grid.Row="0" Height="240" Background="Transparent">
                    <Path Fill="{StaticResource LcNeonBlue}" Stretch="Fill" StrokeThickness="0" Data="M0,0 L260,0 L260,180 Q200,240 140,240 L0,240 Z" />
                </Canvas>

                <StackPanel Grid.Row="1" Margin="18,0" VerticalAlignment="Top">
                    <Button Content="SYS" Style="{StaticResource LcarsNavButton}" Margin="0,0,0,14" />
                    <Button Content="CPU" Style="{StaticResource LcarsNavButton}" Margin="0,0,0,14" />
                    <Button Content="MEM" Style="{StaticResource LcarsNavButton}" Margin="0,0,0,14" />
                    <Button Content="STRG" Style="{StaticResource LcarsNavButton}" />
                </StackPanel>

                <Grid Grid.Row="2" Margin="0" Background="{StaticResource LcGold}">
                    <TextBlock Text="SPOCKY" Foreground="{StaticResource LcBackground}" FontSize="48" FontWeight="Bold" VerticalAlignment="Center" HorizontalAlignment="Center" />
                </Grid>
            </Grid>

            <!-- Main Dashboard -->
            <Grid Grid.Column="1" Margin="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="60" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Margin="20,16,20,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="TEMP" Foreground="{StaticResource LcGold}" FontSize="18" FontWeight="Bold" VerticalAlignment="Center" />
                        <StackPanel Orientation="Horizontal" Margin="12,0,0,0">
                            <Button x:Name="CelsiusButton" Content="°C" Style="{StaticResource LcarsChipButton}" Click="SelectCelsius" />
                            <Button x:Name="FahrenheitButton" Content="°F" Style="{StaticResource LcarsChipButton}" Margin="8,0,0,0" Click="SelectFahrenheit" />
                        </StackPanel>

                        <TextBlock Text="DRIVE" Foreground="{StaticResource LcGold}" FontSize="18" FontWeight="Bold" Margin="28,0,0,0" VerticalAlignment="Center" />
                        <ComboBox x:Name="DriveSelector"
                                  Width="140"
                                  Height="32"
                                  Margin="12,0,0,0"
                                  Style="{StaticResource LcarsComboBox}"
                                  DisplayMemberPath="Label"
                                  SelectedValuePath="Root"
                                  SelectionChanged="OnDriveSelectionChanged" />
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Grid.Column="1">
                        <Button Content="_" Width="40" Height="24" Click="MinimizeWindow" Background="{StaticResource LcViolet}" BorderBrush="{StaticResource LcViolet}" Foreground="{StaticResource LcBackground}" Margin="0,0,12,0" />
                        <Button Content="X" Width="40" Height="24" Click="CloseWindow" Background="{StaticResource LcMutedOrange}" BorderBrush="{StaticResource LcMutedOrange}" Foreground="{StaticResource LcBackground}" />
                    </StackPanel>
                </Grid>

                <Grid Grid.Row="1" Margin="20">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <TextBlock Text="SYSTEM METRICS" Foreground="{StaticResource LcNeonBlue}" FontSize="36" FontWeight="SemiBold" Margin="0,0,0,16" />

                    <UniformGrid Grid.Row="1" Columns="3" Margin="0" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" IsItemsHost="False">
                        <Border Background="{StaticResource LcMutedOrange}" Margin="10" Padding="18" CornerRadius="14">
                            <StackPanel>
                                <TextBlock Text="CPU PACKAGE TEMP" Foreground="{StaticResource LcBackground}" FontSize="20" FontWeight="Bold" />
                                <TextBlock x:Name="CpuTempText" Text="-- °C" Foreground="{StaticResource LcBackground}" FontSize="48" FontWeight="Black" Margin="0,6,0,0" />
                                <TextBlock Text="Live thermal readout" Foreground="{StaticResource LcBackground}" FontSize="16" Opacity="0.9" />
                            </StackPanel>
                        </Border>

                        <Border Background="{StaticResource LcViolet}" Margin="10" Padding="18" CornerRadius="14">
                            <StackPanel>
                                <TextBlock Text="GPU CORE TEMP" Foreground="{StaticResource LcBackground}" FontSize="20" FontWeight="Bold" />
                                <TextBlock x:Name="GpuTempText" Text="-- °C" Foreground="{StaticResource LcBackground}" FontSize="48" FontWeight="Black" Margin="0,6,0,0" />
                                <TextBlock Text="Discrete + integrated" Foreground="{StaticResource LcBackground}" FontSize="16" Opacity="0.9" />
                            </StackPanel>
                        </Border>

                        <Border Background="{StaticResource LcNeonBlue}" Margin="10" Padding="18" CornerRadius="14">
                            <StackPanel>
                                <TextBlock Text="CPU LOAD" Foreground="{StaticResource LcBackground}" FontSize="20" FontWeight="Bold" />
                                <TextBlock x:Name="CpuLoadText" Text="-- %" Foreground="{StaticResource LcBackground}" FontSize="48" FontWeight="Black" Margin="0,6,0,0" />
                                <TextBlock Text="Total utilization" Foreground="{StaticResource LcBackground}" FontSize="16" Opacity="0.9" />
                            </StackPanel>
                        </Border>

                        <Border Background="{StaticResource LcNeonBlue}" Margin="10" Padding="18" CornerRadius="14">
                            <StackPanel>
                                <TextBlock Text="MEMORY USAGE" Foreground="{StaticResource LcBackground}" FontSize="20" FontWeight="Bold" />
                                <TextBlock x:Name="MemoryUsageText" Text="-- %" Foreground="{StaticResource LcBackground}" FontSize="48" FontWeight="Black" Margin="0,6,0,0" />
                                <TextBlock x:Name="MemoryDetailText" Text="-- / -- GB" Foreground="{StaticResource LcBackground}" FontSize="16" Opacity="0.9" />
                            </StackPanel>
                        </Border>

                        <Border Background="{StaticResource LcGold}" Margin="10" Padding="18" CornerRadius="14">
                            <StackPanel>
                                <TextBlock x:Name="StorageTitleText" Text="PRIMARY STORAGE" Foreground="{StaticResource LcBackground}" FontSize="20" FontWeight="Bold" />
                                <TextBlock x:Name="StorageUsageText" Text="-- %" Foreground="{StaticResource LcBackground}" FontSize="48" FontWeight="Black" Margin="0,6,0,0" />
                                <TextBlock x:Name="StorageDetailText" Text="-- / -- GB" Foreground="{StaticResource LcBackground}" FontSize="16" Opacity="0.9" />
                            </StackPanel>
                        </Border>

                        <Border Background="{StaticResource LcViolet}" Margin="10" Padding="18" CornerRadius="14">
                            <StackPanel>
                                <TextBlock Text="CPU CLOCK" Foreground="{StaticResource LcBackground}" FontSize="20" FontWeight="Bold" />
                                <TextBlock x:Name="CpuClockText" Text="-- MHz" Foreground="{StaticResource LcBackground}" FontSize="48" FontWeight="Black" Margin="0,6,0,0" />
                                <TextBlock Text="Current frequency" Foreground="{StaticResource LcBackground}" FontSize="16" Opacity="0.9" />
                            </StackPanel>
                        </Border>

                        <Border Background="{StaticResource LcMutedOrange}" Margin="10" Padding="18" CornerRadius="14">
                            <StackPanel>
                                <TextBlock Text="DISK THROUGHPUT" Foreground="{StaticResource LcBackground}" FontSize="20" FontWeight="Bold" />
                                <TextBlock x:Name="DiskReadText" Text="Read -- MB/s" Foreground="{StaticResource LcBackground}" FontSize="28" FontWeight="Black" Margin="0,6,0,0" />
                                <TextBlock x:Name="DiskWriteText" Text="Write -- MB/s" Foreground="{StaticResource LcBackground}" FontSize="20" />
                            </StackPanel>
                        </Border>

                        <Border Background="{StaticResource LcNeonBlue}" Margin="10" Padding="18" CornerRadius="14">
                            <StackPanel>
                                <TextBlock Text="NETWORK" Foreground="{StaticResource LcBackground}" FontSize="20" FontWeight="Bold" />
                                <TextBlock x:Name="NetworkSendText" Text="Up -- Mb/s" Foreground="{StaticResource LcBackground}" FontSize="28" FontWeight="Black" Margin="0,6,0,0" />
                                <TextBlock x:Name="NetworkReceiveText" Text="Down -- Mb/s" Foreground="{StaticResource LcBackground}" FontSize="20" />
                            </StackPanel>
                        </Border>

                        <Border Background="{StaticResource LcGold}" Margin="10" Padding="18" CornerRadius="14">
                            <StackPanel>
                                <TextBlock Text="SYSTEM UPTIME" Foreground="{StaticResource LcBackground}" FontSize="20" FontWeight="Bold" />
                                <TextBlock x:Name="UptimeText" Text="--" Foreground="{StaticResource LcBackground}" FontSize="42" FontWeight="Black" Margin="0,6,0,0" />
                                <TextBlock Text="Since last boot" Foreground="{StaticResource LcBackground}" FontSize="16" Opacity="0.9" />
                            </StackPanel>
                        </Border>

                        <Border Background="{StaticResource LcViolet}" Margin="10" Padding="18" CornerRadius="14">
                            <StackPanel>
                                <TextBlock Text="BATTERY" Foreground="{StaticResource LcBackground}" FontSize="20" FontWeight="Bold" />
                                <TextBlock x:Name="BatteryPercentText" Text="-- %" Foreground="{StaticResource LcBackground}" FontSize="42" FontWeight="Black" Margin="0,6,0,0" />
                                <TextBlock x:Name="BatteryStatusText" Text="No battery" Foreground="{StaticResource LcBackground}" FontSize="16" Opacity="0.9" />
                            </StackPanel>
                        </Border>
                    </UniformGrid>
                </Grid>
            </Grid>
        </Grid>
    </Border>
</Window>
