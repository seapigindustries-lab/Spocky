<Application x:Class="Spocky.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:Spocky"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <ResourceDictionary>
            <Color x:Key="LcBackground">#FF000000</Color>
            <Color x:Key="LcMutedOrange">#FFFF9900</Color>
            <Color x:Key="LcViolet">#FFCC99CC</Color>
            <Color x:Key="LcNeonBlue">#FF6699CC</Color>
            <Color x:Key="LcGold">#FFFFCC00</Color>
        </ResourceDictionary>
    </Application.Resources>
</Application>
