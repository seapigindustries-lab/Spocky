<Application x:Class="Spocky.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:Spocky"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <ResourceDictionary>
            <SolidColorBrush x:Key="LcBackground" Color="#FF000000" />
            <SolidColorBrush x:Key="LcMutedOrange" Color="#FFFF9900" />
            <SolidColorBrush x:Key="LcViolet" Color="#FFCC99CC" />
            <SolidColorBrush x:Key="LcNeonBlue" Color="#FF6699CC" />
            <SolidColorBrush x:Key="LcGold" Color="#FFFFCC00" />
        </ResourceDictionary>
    </Application.Resources>
</Application>
